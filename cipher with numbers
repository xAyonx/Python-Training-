# 1. Die "Werkzeuge" bereitlegen
alphabet = ['a', 'b', 'c', 'd', 'e', 'f', 'g', 'h', 'i', 'j', 'k', 'l', 'm', 'n', 'o', 'p', 'q', 'r', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z']

# 2. Die "Fabrik" definieren (Bauplan)
def caesar(original_text, shift_amount, encode_or_decode):
    output_text = ""
    
    # Wenn wir entschlüsseln, müssen wir rückwärts gehen (- statt +)
    if encode_or_decode == "decode":
        shift_amount *= -1
        
    for letter in original_text:
        if letter not in alphabet:
            # Sonderzeichen einfach übernehmen
            output_text += letter
        else:
            # Den neuen Index berechnen
            shifted_position = (alphabet.index(letter) + shift_amount) % len(alphabet)
            output_text += alphabet[shifted_position]
            
    print(f"Here is the {encode_or_decode}d result: {output_text}")

# 3. Den User fragen (Daten sammeln)
direction = input("Type 'encode' to encrypt, type 'decode' to decrypt:\n").lower()
text = input("Type your message:\n").lower()
shift = int(input("Type the shift number:\n"))

# 4. Die Fabrik STARTEN (Der Aufruf am linken Rand)
caesar(original_text=text, shift_amount=shift, encode_or_decode=direction)
